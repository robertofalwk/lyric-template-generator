{
  "name": "lyric-template-generator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "worker": "tsx watch src/server/worker.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run worker\"",
    "setup": "npm install && npm run db:init && npm run check:env",
    "db:init": "tsx src/scripts/init-db.ts",
    "db:reset": "rimraf storage/database.sqlite && npm run db:init",
    "healthcheck": "tsx src/scripts/check-health.ts",
    "check:env": "tsx src/scripts/check-env.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "render": "remotion render remotion/Root.tsx"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.448",
    "@remotion/google-fonts": "^4.0.448",
    "@remotion/player": "^4.0.448",
    "@remotion/renderer": "^4.0.448",
    "@types/uuid": "^10.0.0",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remotion": "^4.0.448",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
