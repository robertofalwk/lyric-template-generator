# --- Lyric Lab Platform Config ---

# AI Provider Configuration (local | openai)
TEMPLATE_AI_PROVIDER=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Technical Settings
TEMPLATE_AI_TIMEOUT_MS=20000
TEMPLATE_AI_ENABLE_FALLBACK=true

# Storage
DATABASE_PATH=./storage/database.sqlite
UPLOAD_DIR=./public/uploads
EXPORT_DIR=./public/exports
